{
  "version": "1.1",
  "parameters": {
    "Region": {
      "type": "string",
      "required": false
    }
  },
  "conditions": [
    {
      "fn": "isSet",
      "argv": [{"ref": "Region"}]
    },
    {
      "fn": "aws.partition",
      "argv": [{"ref": "Region"}],
      "assign": "partitionResult"
    }
  ],
  "results": [
    {
      "endpoint": {
        "url": "https://example.{Region}.{partitionResult#dnsSuffix}"
      }
    },
    {
      "error": "unable to determine endpoint for region: {Region}"
    },
    {
      "endpoint": {
        "url": "https://example.amazonaws.com"
      }
    }
  ],
  "root": 2,
  "nodeCount": 3,
  "nodes": "/////wAAAAH/////AAAAAAAAAAMF9eEDAAAAAQX14QEF9eEC"
}
