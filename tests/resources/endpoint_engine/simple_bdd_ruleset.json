{
  "version": "1.1",
  "parameters": {
    "Region": {
      "type": "string",
      "required": false
    }
  },
  "conditions": [
    {
      "fn": "isSet",
      "argv": [{"ref": "Region"}]
    },
    {
      "fn": "aws.partition",
      "argv": [{"ref": "Region"}],
      "assign": "partitionResult"
    }
  ],
  "results": [
    {
      "endpoint": {
        "url": "https://example.{Region}.{partitionResult#dnsSuffix}",
        "headers": {
          "x-amz-region": ["{Region}"],
          "x-amz-multi": ["*", "{Region}"]
        },
        "properties": {
          "authSchemes": [
            {
              "name": "sigv4",
              "signingName": "serviceName",
              "signingRegion": "{Region}"
            }
          ]
        }
      }
    },
    {
      "error": "unable to determine endpoint for region: {Region}"
    },
    {
      "endpoint": {
        "url": "https://example.amazonaws.com"
      }
    }
  ],
  "root": 2,
  "nodeCount": 2,
  "nodes": "AAAAAAAAAAMF9eEDAAAAAQX14QEF9eEC"
}
